            async updateCartItemOptions(item) {
                const modal = $(`#optionModal-${item.id}`);
                const inputs = modal.find('input, select, textarea');

                let isValid = true;
                modal.find('[required]').each(function() {
                    if ($(this).is('input[type="checkbox"], input[type="radio"]')) {
                        if (!modal.find('[name="' + $(this).attr('name') + '"]:checked').length) {
                            $(this).addClass('is-invalid');
                            isValid = false;
                        } else {
                            $(this).removeClass('is-invalid');
